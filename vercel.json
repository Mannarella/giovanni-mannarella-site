{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build:static",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
